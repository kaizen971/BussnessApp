# ============================================================
#  GESTION DES ENVIRONNEMENTS
# ============================================================
#
# Le projet utilise 3 fichiers .env :
#   - .env              -> selecteur (contient juste APP_ENV)
#   - .env.local        -> config dev / localhost
#   - .env.production   -> config production
#
# Comment basculer :
#   1) Editer .env et mettre APP_ENV=local ou APP_ENV=production
#      puis lancer : npm start  ou  npm run dev
#
#   2) Forcer en CLI (sans modifier .env) :
#      npm run start:local
#      npm run start:prod
#      npm run dev:local
#      npm run dev:prod
#
# ============================================================

# Variable de selection (a placer dans .env)
APP_ENV=production

# ============================================================
# Variables a placer dans .env.local et .env.production
# ============================================================

# MongoDB
MONGODB_URI=mongodb+srv://...

# JWT
JWT_SECRET=votre_super_secret_jwt_qui_doit_etre_tres_long_et_complexe_123!

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email SMTP (Gmail exemple)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app
SMTP_FROM="BussnessApp" <votre-email@gmail.com>

# URLs
# .env.local        : http://localhost:5173  /  http://localhost:3003
# .env.production   : https://businessapp.installpostiz.com  /  .../bussnessapp
BACKOFFICE_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:3003

# Backoffice Security
BACKOFFICE_ACCESS_KEY=votre_code_acces_portal_secret
BACKOFFICE_INIT_SECRET=votre_secret_initialisation_superadmin

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-north-1
S3_BUCKET_NAME=bussnessapp-photos
